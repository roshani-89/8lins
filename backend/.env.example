# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/8lines_db

# JWT
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# OTP (Twilio or Fast2SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Fast2SMS (Indian OTP - cheaper alternative)
FAST2SMS_API_KEY=your_fast2sms_api_key

# Razorpay
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret

# AWS S3
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1
S3_BUCKET_NAME=8lines-kyc-documents

# Redis (for OTP caching)
REDIS_URL=redis://localhost:6379/0

# CORS
FRONTEND_URL=http://localhost:3000

# Email (SendGrid or SMTP)
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXX
FROM_EMAIL=noreply@8linesgroup.com

# Environment
ENVIRONMENT=development
